{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_ROOT}/.claude/hooks/scripts/suggest-compact.js"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_ROOT}/.claude/hooks/scripts/doc-blocker.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_ROOT}/.claude/hooks/scripts/pre-compact.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_ROOT}/.claude/hooks/scripts/session-start.js"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_ROOT}/.claude/hooks/scripts/session-end.js"
          }
        ]
      }
    ]
  }
}
